# Flickr OAuth
FLICKR_API_KEY=your_flickr_api_key
FLICKR_API_SECRET=your_flickr_api_secret

# App-level password gate (bcrypt is overkill for one personal user;
# this is plain text and never sent to the client).
APP_PASSWORD=set-something-strong

# HMAC key for signing the session cookie. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=set-a-long-random-string

# URL the app is reached at. SvelteKit uses this for form-action and
# OAuth-callback origin checks.
ORIGIN=http://localhost:5173
